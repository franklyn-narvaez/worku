DATABASE_URL_DEV=postgresql://user:password@localhost:5432/dbdev
DATABASE_URL_TEST=postgresql://test:test@localhost:5433/test
# Fallback database URL, used if DATABASE_URL_DEV or DATABASE_URL_TEST are not set
DATABASE_URL=postgresql://test:test@localhost:5433/test

# Set MODE to 'dev' for development or 'test' for running tests
MODE=dev

# JWT Secrets (change these in production!)
JWT_SECRET=your_jwt_secret_key_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me

# Email Configuration (SMTP)
# Opción 1: Usar Ethereal (test fake SMTP - funciona sin configuración)
USE_ETHEREAL=tru

Opción 2: Usar SMTP real (descomenta y configura si prefieres)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Node Environment
NODE_ENV=development
